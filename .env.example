# ── Gateway ────────────────────────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgres://babji:babji_dev@localhost:5432/babji
POSTGRES_PASSWORD=your_secure_password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Memory ────────────────────────────────────────────────────────
MEMORY_BASE_DIR=./data/tenants

# ── Encryption ────────────────────────────────────────────────────
ENCRYPTION_KEY=your_64_char_hex_key_here

# ── LLM API Keys ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# ── Channels ──────────────────────────────────────────────────────
WHATSAPP_ENABLED=true
TELEGRAM_BOT_TOKEN=

# ── OAuth (Google) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ── OAuth (Meta) ──────────────────────────────────────────────────
META_CLIENT_ID=...
META_CLIENT_SECRET=...

# ── OAuth (LinkedIn) ──────────────────────────────────────────────
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...

# ── OAuth (X/Twitter) ────────────────────────────────────────────
X_CLIENT_ID=...
X_CLIENT_SECRET=...

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREPAID_100=price_...
STRIPE_PRICE_PREPAID_200=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# ── URLs ──────────────────────────────────────────────────────────
OAUTH_PORTAL_URL=https://auth.babji.ai
APP_URL=https://app.babji.ai
